{
  "name": "seur-kiosk-pwa",
  "private": true,
  "description": "Test runner for the SEUR kiosk PWA",
  "scripts": {
    "test": "npm run test:static && npm run test:e2e",
    "test:static": "node --test tests/static/shell.test.js tests/static/assets.test.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "supabase": "^2.78.1"
  }
}
